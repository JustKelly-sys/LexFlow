{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "frontend/",
      "framework": "vite",
      "rewrites": [
        { "source": "/(.*)", "destination": "/index.html" }
      ]
    },
    "api": {
      "root": ".",
      "framework": "fastapi",
      "entrypoint": "main:app",
      "installCommand": "pip install -r api/requirements.txt"
    }
  },
  "rewrites": [
    { "source": "/transcribe", "destination": { "service": "api" } },
    { "source": "/billing", "destination": { "service": "api" } },
    { "source": "/billing/(.*)", "destination": { "service": "api" } },
    { "source": "/profile", "destination": { "service": "api" } },
    { "source": "/demo/(.*)", "destination": { "service": "api" } },
    { "source": "/webhook", "destination": { "service": "api" } },
    { "source": "/whatsapp/link", "destination": { "service": "api" } },
    { "source": "/health", "destination": { "service": "api" } },
    { "source": "/(.*)", "destination": { "service": "web" } }
  ]
}
