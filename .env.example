# LexFlow Environment Variables
# Copy this file to .env and fill in your values

# ── Backend (main.py) ──────────────────────────────────
# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model (optional, defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Supabase project credentials (required)
# Find these in: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Frontend (frontend/.env) ───────────────────────────
# Also create frontend/.env with these values:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
#
# NOTE: The anon key is designed to be public (like a Firebase API key).
# It only grants access through Row Level Security policies.
