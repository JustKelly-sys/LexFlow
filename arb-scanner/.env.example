# Polymarket Arbitrage Scanner Environment Configuration

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (for market categorization)
OPENAI_API_KEY=your_openai_key_here

# Stripe (for payments - optional for MVP)
STRIPE_SECRET_KEY=your_stripe_sk_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# Polymarket API
POLYMARKET_WS_URL=wss://ws-subscriptions.polymarket.com/ws/markets
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Scanner Configuration
PROFIT_THRESHOLD_PCT=1.0
SCAN_INTERVAL_SECONDS=5
TAKER_FEE_PCT=2.0
GAS_COST_USD=0.005
SLIPPAGE_BUFFER_PCT=0.5

# Database
DB_PATH=./data/scanner.db

# Logging
LOG_LEVEL=INFO

# Payment wallet addresses
PAYMENT_WALLET_POLYGON=0x6f1CD1F04B890Afa648732e707D22378B240F20f
PAYMENT_WALLET_ETHEREUM=0x6f1CD1F04B890Afa648732e707D22378B240F20f
PAYMENT_WALLET_SOLANA=BLutXqkQpZkvNzPGNisnJ17fEjZ2MJ1Avc9QkXMRAhQb

# Blockchain API keys (get free at polygonscan.com and etherscan.io)
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
